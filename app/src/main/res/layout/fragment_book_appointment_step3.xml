<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Progress Indicator -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="32dp">

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/progress_circle"/>

            <View
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:background="#2196F3"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"/>

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/progress_circle"/>

        </LinearLayout>

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Payment Method"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Please select the document details below. This will only take a few minutes."
            android:textSize="13sp"
            android:textColor="#9E9E9E"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="32dp"/>

        <!-- Amount Paid Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Amount Paid"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Please enter your accurate student information and specify the reason for this request"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:layout_marginBottom="16dp"/>

        <!-- Cash Denomination Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cash Denomination"
            android:textSize="14sp"
            android:textColor="#424242"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etCashDenomination"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Ex. (1000, 500, 200, 100, 50 and 20)"
            android:textColorHint="#BDBDBD"
            android:inputType="text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="16dp"/>

        <!-- No. of Pieces Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No. of Pieces"
            android:textSize="14sp"
            android:textColor="#424242"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etNoPieces"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Ex. (1, 2, and 3)"
            android:textColorHint="#BDBDBD"
            android:inputType="text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="16dp"/>

        <!-- Amount Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total Amount"
            android:textSize="14sp"
            android:textColor="#424242"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etAmount"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Ex. (5000)"
            android:textColorHint="#BDBDBD"
            android:inputType="numberDecimal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="24dp"/>

        <!-- Payment Method Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Payment Method"
            android:textSize="14sp"
            android:textColor="#424242"
            android:layout_marginBottom="8dp"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <Spinner
                android:id="@+id/spinnerPaymentMethod"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:padding="16dp"
                android:background="@android:drawable/edit_text"
                android:spinnerMode="dropdown"/>

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="12dp"
                android:src="@android:drawable/arrow_down_float"
                android:contentDescription="Dropdown arrow"/>

        </RelativeLayout>

        <!-- Dynamic Payment Fields Container -->
        <LinearLayout
            android:id="@+id/layoutDynamicFields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="32dp">

            <!-- Fields will be added dynamically based on payment method selection -->
        </LinearLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="100dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btnBack"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="← Back"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="8dp"
                android:background="@drawable/button_primary"/>

            <Button
                android:id="@+id/btnSubmit"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Submit"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:layout_marginStart="8dp"
                android:background="@drawable/button_primary"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>