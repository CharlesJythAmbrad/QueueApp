<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Request Queue"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Please select the document details below. This will only take a few minutes."
            android:textSize="13sp"
            android:textColor="#9E9E9E"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="32dp"/>

        <!-- Location Status -->
        <TextView
            android:id="@+id/tvLocationStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Checking location..."
            android:textSize="13sp"
            android:padding="12dp"
            android:background="#E3F2FD"
            android:layout_marginBottom="24dp"/>

        <!-- Transaction Type -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Transaction Type"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Please check the details of name of the transaction requested"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:layout_marginBottom="16dp"/>

        <RadioGroup
            android:id="@+id/rgTransactionType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp">

            <RadioButton
                android:id="@+id/rbRequestRegistrar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Request Registrar Queue"
                android:textSize="15sp"
                android:textColor="#424242"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"/>

            <RadioButton
                android:id="@+id/rbRequestFinance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Request Finance Queue"
                android:textSize="15sp"
                android:textColor="#424242"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:checked="true"/>
        </RadioGroup>

        <!-- Student Details -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Student Details"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Please write your accurate information and specify the reason for this request"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:layout_marginBottom="16dp"/>

        <!-- Name Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textSize="14sp"
            android:textColor="#424242"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Ex. (Harry Belia)"
            android:textColorHint="#BDBDBD"
            android:inputType="textPersonName"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="16dp"/>

        <!-- Course/Strand Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Course/Strand"
            android:textSize="14sp"
            android:textColor="#424242"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etCourse"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Ex. (BS Information Technology)"
            android:textColorHint="#BDBDBD"
            android:inputType="text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="16dp"/>

        <!-- Student ID Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Student ID"
            android:textSize="14sp"
            android:textColor="#424242"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etStudentId"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Ex. (05-2324-000000)"
            android:textColorHint="#BDBDBD"
            android:inputType="text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="16dp"/>

        <!-- Mobile Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mobile"
            android:textSize="14sp"
            android:textColor="#424242"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etMobile"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Ex. (0523240000)"
            android:textColorHint="#BDBDBD"
            android:inputType="phone"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="32dp"/>

        <!-- Next Button -->
        <Button
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Next →"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1976D2"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="100dp"/>

    </LinearLayout>
</ScrollView>
