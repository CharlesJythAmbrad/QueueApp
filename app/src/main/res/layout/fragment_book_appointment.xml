<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Request Queue"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/primary_color"
            android:layout_gravity="center"
            android:layout_marginBottom="12dp"/>

        <!-- Location Status -->
        <TextView
            android:id="@+id/tvLocationStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Checking location..."
            android:textSize="14sp"
            android:textAlignment="center"
            android:padding="8dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:layout_marginBottom="20dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Request Registrar Queue Button -->
                <Button
                    android:id="@+id/btnRequestRegistrar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📋 Request Registrar Queue"
                    android:textSize="16sp"
                    android:backgroundTint="#FF6F00"
                    android:layout_marginBottom="20dp"/>

                <!-- Transaction Type -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Transaction Type"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <RadioGroup
                    android:id="@+id/rgTransactionType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp">

                    <RadioButton
                        android:id="@+id/rbDownPayment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💰 Down Payment"
                        android:textSize="16sp"
                        android:padding="12dp"/>

                    <RadioButton
                        android:id="@+id/rbInstallment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📅 Installment Payment"
                        android:textSize="16sp"
                        android:padding="12dp"/>

                    <RadioButton
                        android:id="@+id/rbBalance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💳 Balance Payment"
                        android:textSize="16sp"
                        android:padding="12dp"/>
                </RadioGroup>

                <!-- Student Details Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Student Details"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <!-- Name (Auto-filled, Read-only) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Name"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Loading..."
                    android:enabled="false"
                    android:textColor="@android:color/black"
                    android:layout_marginBottom="12dp"/>

                <!-- Course (Auto-filled, Read-only) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Course / Strand"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etCourse"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Loading..."
                    android:enabled="false"
                    android:textColor="@android:color/black"
                    android:layout_marginBottom="12dp"/>

                <!-- Student ID (Auto-filled, Read-only) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Student ID #"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etStudentId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Loading..."
                    android:enabled="false"
                    android:textColor="@android:color/black"
                    android:layout_marginBottom="12dp"/>

                <!-- Mobile Number (Editable) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mobile #"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etMobile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="09XXXXXXXXX"
                    android:inputType="phone"
                    android:layout_marginBottom="20dp"/>

                <!-- Payment Details Section (Hidden by default) -->
                <LinearLayout
                    android:id="@+id/layoutPaymentDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@android:color/darker_gray"
                        android:layout_marginVertical="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Payment Details"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <!-- Purpose of Payment -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Purpose of Payment"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etPurpose1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="1. "
                        android:layout_marginBottom="8dp"/>

                    <EditText
                        android:id="@+id/etPurpose2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="2. "
                        android:layout_marginBottom="8dp"/>

                    <EditText
                        android:id="@+id/etPurpose3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="3. "
                        android:layout_marginBottom="12dp"/>

                    <!-- Total Amount -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Amount Paid (₱)"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etTotalAmount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="0.00"
                        android:inputType="numberDecimal"
                        android:layout_marginBottom="16dp"/>

                    <!-- Cash Denomination Table -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cash Denomination"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Denomination"
                            android:textStyle="bold"
                            android:padding="8dp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="No. of Pieces"
                            android:textStyle="bold"
                            android:padding="8dp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Amount"
                            android:textStyle="bold"
                            android:padding="8dp"/>
                    </LinearLayout>

                    <!-- 1000 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="1,000.00"
                            android:padding="8dp"/>

                        <EditText
                            android:id="@+id/etPieces1000"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="0"
                            android:inputType="number"
                            android:padding="8dp"/>

                        <TextView
                            android:id="@+id/tvAmount1000"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0.00"
                            android:padding="8dp"/>
                    </LinearLayout>

                    <!-- 500 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="500.00"
                            android:padding="8dp"/>

                        <EditText
                            android:id="@+id/etPieces500"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="0"
                            android:inputType="number"
                            android:padding="8dp"/>

                        <TextView
                            android:id="@+id/tvAmount500"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0.00"
                            android:padding="8dp"/>
                    </LinearLayout>

                    <!-- 200 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="200.00"
                            android:padding="8dp"/>

                        <EditText
                            android:id="@+id/etPieces200"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="0"
                            android:inputType="number"
                            android:padding="8dp"/>

                        <TextView
                            android:id="@+id/tvAmount200"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0.00"
                            android:padding="8dp"/>
                    </LinearLayout>

                    <!-- 100 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="100.00"
                            android:padding="8dp"/>

                        <EditText
                            android:id="@+id/etPieces100"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="0"
                            android:inputType="number"
                            android:padding="8dp"/>

                        <TextView
                            android:id="@+id/tvAmount100"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0.00"
                            android:padding="8dp"/>
                    </LinearLayout>

                    <!-- 50 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="50.00"
                            android:padding="8dp"/>

                        <EditText
                            android:id="@+id/etPieces50"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="0"
                            android:inputType="number"
                            android:padding="8dp"/>

                        <TextView
                            android:id="@+id/tvAmount50"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0.00"
                            android:padding="8dp"/>
                    </LinearLayout>

                    <!-- 20 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="20.00"
                            android:padding="8dp"/>

                        <EditText
                            android:id="@+id/etPieces20"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="0"
                            android:inputType="number"
                            android:padding="8dp"/>

                        <TextView
                            android:id="@+id/tvAmount20"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0.00"
                            android:padding="8dp"/>
                    </LinearLayout>

                    <!-- Coins -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="COINS"
                            android:padding="8dp"/>

                        <EditText
                            android:id="@+id/etCoins"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="0.00"
                            android:inputType="numberDecimal"
                            android:padding="8dp"/>

                        <TextView
                            android:id="@+id/tvAmountCoins"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0.00"
                            android:padding="8dp"/>
                    </LinearLayout>

                    <!-- Total Cash Tendered -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Cash Tendered: ₱"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvTotalCashTendered"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0.00"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_color"
                        android:layout_marginBottom="12dp"/>

                    <!-- Change -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Change: ₱"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvChange"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0.00"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#2E7D32"
                        android:layout_marginBottom="20dp"/>

                    <!-- Card Payment Checkbox -->
                    <CheckBox
                        android:id="@+id/cbCardPayment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Card Payment"
                        android:textSize="16sp"
                        android:layout_marginBottom="12dp"/>

                    <!-- Card Payment Details (Hidden by default) -->
                    <LinearLayout
                        android:id="@+id/layoutCardDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Card Type"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>

                        <RadioGroup
                            android:id="@+id/rgCardType"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <RadioButton
                                android:id="@+id/rbDebit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Debit"
                                android:checked="true"/>

                            <RadioButton
                                android:id="@+id/rbCredit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Credit"
                                android:layout_marginStart="16dp"/>
                        </RadioGroup>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Card Holder Name"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>

                        <EditText
                            android:id="@+id/etCardHolderName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Enter card holder name"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bank"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>

                        <EditText
                            android:id="@+id/etBank"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Enter bank name"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Amount"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>

                        <EditText
                            android:id="@+id/etCardAmount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="0.00"
                            android:inputType="numberDecimal"
                            android:layout_marginBottom="16dp"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- Submit Button -->
                <Button
                    android:id="@+id/btnSubmitQueue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Submit Queue Request"
                    android:textSize="16sp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="80dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
